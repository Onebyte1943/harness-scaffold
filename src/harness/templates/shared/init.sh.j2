#!/usr/bin/env bash
# init.sh — {{ project_name }}
# Generated by harness v{{ harness_version }} at {{ timestamp }}
#
# This is the SINGLE entry script every agent runs at session start
# (per AGENTS.md § 5.1 Session Contract / Resume).
#
# It does three things, in order:
#   1. Print the project summary so the agent knows where it is.
#   2. Run cheap environment health checks.
#   3. Call .harness/scripts/{{ script_shell }}/verify.sh.
#
# If init.sh is red, repair it before adding new scope.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- 1. Summary ----------------------------------------------------

echo "=== Harness — {{ project_name }} ==="
echo "  profile     : {{ profile }}"
echo "  flow        : {{ flow }}"
echo "  lang        : {{ lang }}"
echo "  output_lang : {{ output_lang }}"
echo "  agents      : {{ agents | join(', ') }}"
echo

ACTIVE_SPEC=""
if [ -d "$SCRIPT_DIR/specs" ]; then
    # Heuristic: most-recently-modified spec dir.
    ACTIVE_SPEC="$(ls -1t "$SCRIPT_DIR/specs" 2>/dev/null | head -n1 || true)"
fi
if [ -n "$ACTIVE_SPEC" ]; then
    echo "  active spec : $ACTIVE_SPEC"
else
    echo "  active spec : (none yet — run /hx-propose to start)"
fi
echo

# --- 2. Environment health ----------------------------------------

echo "=== Environment ==="

if ! command -v git >/dev/null 2>&1; then
    echo "  warn: git not on PATH"
else
    GIT_BRANCH="$(git -C "$SCRIPT_DIR" symbolic-ref --short HEAD 2>/dev/null || echo 'detached')"
    GIT_DIRTY="$(git -C "$SCRIPT_DIR" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
    echo "  git branch  : $GIT_BRANCH"
    echo "  git dirty   : $GIT_DIRTY file(s)"
fi

# Stack-specific quick checks. Extend during /hx-baseline.
if [ -f "$SCRIPT_DIR/pyproject.toml" ]; then
    if command -v uv >/dev/null 2>&1; then
        echo "  python      : $(uv run python -V 2>/dev/null || echo 'not ready')"
    elif command -v python >/dev/null 2>&1; then
        echo "  python      : $(python -V 2>/dev/null)"
    fi
fi
if [ -f "$SCRIPT_DIR/package.json" ]; then
    command -v node >/dev/null 2>&1 && echo "  node        : $(node -v)"
fi
echo

# --- 3. Verify ----------------------------------------------------

VERIFY="$SCRIPT_DIR/.harness/scripts/{{ script_shell }}/verify.sh"
LAST_VERIFY="$SCRIPT_DIR/.harness/.last-verify.json"
if [ ! -x "$VERIFY" ]; then
    echo "warn: $VERIFY not executable; skipping verify"
    exit 0
fi

echo "=== Verify ==="
if "$VERIFY" "${1:-all}"; then
    # Record green run for `harness state pass` freshness gate
    # (AGENTS.md § 2.3, default 5-minute window).
    cat > "$LAST_VERIFY" <<EOF
{"status":"green","timestamp":$(date +%s),"target":"${1:-all}"}
EOF
    exit 0
else
    rc=$?
    cat > "$LAST_VERIFY" <<EOF
{"status":"red","timestamp":$(date +%s),"target":"${1:-all}","exit_code":$rc}
EOF
    exit $rc
fi
