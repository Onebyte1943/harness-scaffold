# init.ps1 — {{ project_name }}
# Generated by harness v{{ harness_version }} at {{ timestamp }}
#
# Single entry script every agent runs at session start
# (per AGENTS.md section 5.1 Session Contract / Resume).
# Mirrors init.sh on POSIX.

$ErrorActionPreference = "Stop"
$ScriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path

# --- 1. Summary ----------------------------------------------------

Write-Host "=== Harness — {{ project_name }} ==="
Write-Host "  profile     : {{ profile }}"
Write-Host "  flow        : {{ flow }}"
Write-Host "  lang        : {{ lang }}"
Write-Host "  output_lang : {{ output_lang }}"
Write-Host "  agents      : {{ agents | join(', ') }}"
Write-Host ""

$ActiveSpec = ""
if (Test-Path "$ScriptDir/specs") {
    $ActiveSpec = (Get-ChildItem "$ScriptDir/specs" -Directory |
        Sort-Object LastWriteTime -Descending |
        Select-Object -First 1).Name
}
if ($ActiveSpec) {
    Write-Host "  active spec : $ActiveSpec"
} else {
    Write-Host "  active spec : (none yet — run /hx-propose to start)"
}
Write-Host ""

# --- 2. Environment health ----------------------------------------

Write-Host "=== Environment ==="

if (Get-Command git -ErrorAction SilentlyContinue) {
    $Branch = (git -C $ScriptDir symbolic-ref --short HEAD 2>$null)
    if (-not $Branch) { $Branch = "detached" }
    $Dirty = (git -C $ScriptDir status --porcelain 2>$null | Measure-Object -Line).Lines
    Write-Host "  git branch  : $Branch"
    Write-Host "  git dirty   : $Dirty file(s)"
} else {
    Write-Host "  warn: git not on PATH"
}
Write-Host ""

# --- 3. Verify ----------------------------------------------------

$Verify = Join-Path $ScriptDir ".harness\scripts\{{ script_shell }}\verify.ps1"
$LastVerify = Join-Path $ScriptDir ".harness\.last-verify.json"
if (-not (Test-Path $Verify)) {
    Write-Host "warn: $Verify not found; skipping verify"
    exit 0
}

Write-Host "=== Verify ==="
$Target = if ($args.Count -gt 0) { $args[0] } else { "all" }
& $Verify $Target
$rc = $LASTEXITCODE
$ts = [int][double]::Parse((Get-Date -UFormat %s))
if ($rc -eq 0) {
    @{ status = "green"; timestamp = $ts; target = $Target } |
        ConvertTo-Json -Compress | Set-Content $LastVerify
} else {
    @{ status = "red"; timestamp = $ts; target = $Target; exit_code = $rc } |
        ConvertTo-Json -Compress | Set-Content $LastVerify
}
exit $rc
