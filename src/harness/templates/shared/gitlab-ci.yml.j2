# GitLab CI for {{ project_name }}
#
# Generated by harness v{{ harness_version }} at {{ timestamp }}.
#
# Two pipeline modes:
#   1. Merge Request pipeline — deterministic verify + inferential review.
#   2. Scheduled pipeline      — reference validator + knowledge↔code drift.
#
# Single source of truth: .harness/scripts/{{ script_shell }}/verify.sh.
# Editor hook (fast), pre-commit (fast), and CI (full) all invoke the same
# script — no two sensors can disagree about whether the build is green.

stages:
  - fast-verify
  - verify
  - review
  - scheduled-drift

default:
  image: ubuntu:24.04
  before_script:
    - apt-get update -qq && apt-get install -y -qq git
  interruptible: true

# ── Merge Request pipeline ────────────────────────────────────────────────

fast-verify:
  stage: fast-verify
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
  script:
    - .harness/scripts/{{ script_shell }}/verify.sh --fast

verify:
  stage: verify
  needs: [fast-verify]
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
  script:
    - .harness/scripts/{{ script_shell }}/verify.sh

review:
  stage: review
  needs: [verify]
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
  script:
    # Placeholder — wire up to your team's CI agent invoker for /hx-review.
    # See .harness/playbooks/50-review.md for the review contract.
    - echo "Invoke /hx-review via your CI agent of choice."
    - echo "Inputs: MR diff, specs/NNN-*/, .harness/memory/constitution.md."
    - echo "Outputs: review report with VERDICT: ship | fix-then-ship."
  allow_failure: true

# ── Scheduled pipeline (drift / reference validation) ────────────────────

reference-validator:
  stage: scheduled-drift
  rules:
    - if: '$CI_PIPELINE_SOURCE == "schedule"'
  script:
    # Validate every `path:line` citation in .harness/knowledge/ and specs/
    # still resolves to an existing file/line.
    - echo "TODO: reference validator — implement in .harness/scripts/{{ script_shell }}/lib/refcheck.sh."

knowledge-code-drift:
  stage: scheduled-drift
  rules:
    - if: '$CI_PIPELINE_SOURCE == "schedule"'
  script:
    # Detect drift between .harness/knowledge/ and the codebase: removed
    # symbols, renamed modules, interface signatures that no longer match.
    - echo "TODO: knowledge↔code drift — implement in .harness/scripts/{{ script_shell }}/lib/drift.sh."

