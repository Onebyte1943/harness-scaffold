# 单一真相源:每个 hook 都调用
# .harness/scripts/{{ script_shell }}/verify.sh —— 与 pre-commit
# 和 CI 共用同一脚本。本文件保持最小;规则放在 verify.sh 里。

repos:
  - repo: local
    hooks:
      - id: harness-verify-fast
        name: harness verify --fast (lint + typecheck)
        entry: .harness/scripts/{{ script_shell }}/verify.sh --fast
        language: system
        pass_filenames: false
        stages: [commit]
