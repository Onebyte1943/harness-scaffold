# Harness Project Configuration
# Generated by harness v{{ harness_version }} at {{ timestamp }}
#
# Mutable user-facing settings only. Canonical paths live in
# src/harness/core/layout.py (single source of truth) — re-running
# `harness init --force` updates this file.

[harness]
profile = "{{ profile }}"
flow = "{{ flow }}"
lang = "{{ lang }}"
agents = [{{ agents | map('tojson') | join(', ') }}]
script_shell = "{{ script_shell }}"
presets = [{{ presets | map('tojson') | join(', ') }}]
output_lang = "{{ output_lang }}"
