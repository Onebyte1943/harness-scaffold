# Harness Adapter Registry
# Generated by harness v{{ harness_version }} at {{ timestamp }}
#
# Adapter spec per supported AI agent terminal: where its config lives,
# how playbook commands are invoked, and which capabilities it offers
# (§14.7 terminal capability matrix). Playbooks degrade gracefully on
# terminals that lack a capability — never silently skip a gate.

[adapters.claude]
type            = "cli"
config_dir      = ".claude"
context_file    = "CLAUDE.md"
commands_dir    = ".claude/commands"
command_format  = "/hx-{cmd}"
templates_dir   = "claude"

[adapters.claude.capabilities.slash_commands]
supported   = true
required    = false
degradation = "Reference playbooks directly from CLAUDE.md / AGENTS.md."

[adapters.claude.capabilities.subagent]
supported   = true
required    = false
degradation = "Run sequentially in main session."

[adapters.claude.capabilities.hook]
supported   = true
required    = false
degradation = "Fall back to pre-commit + CI verify."

[adapters.claude.capabilities.context_import]
supported   = true
required    = false
degradation = "Inline shared context (use @AGENTS.md import when available)."

[adapters.claude.capabilities.mcp]
supported   = true
required    = false
degradation = "Run tools directly via shell."

[adapters.claude.capabilities.file_attach]
supported   = true
required    = false
degradation = "Paste file contents into the prompt."

[adapters.codex]
type            = "cli"
config_dir      = ".codex"
context_file    = "AGENTS.md"
commands_dir    = ".codex/commands"
command_format  = "/hx-{cmd}"
templates_dir   = "codex"

[adapters.codex.capabilities.slash_commands]
supported   = true
required    = false
degradation = "Reference playbooks directly from AGENTS.md."

[adapters.codex.capabilities.subagent]
supported   = false
required    = false
degradation = "Run all steps in a single session."

[adapters.codex.capabilities.hook]
supported   = false
required    = false
degradation = "Use pre-commit + CI verify only."

[adapters.codex.capabilities.context_import]
supported   = true
required    = false
degradation = "Inline shared context in AGENTS.md."

[adapters.codex.capabilities.mcp]
supported   = false
required    = false
degradation = "Run tools directly via shell."

[adapters.codex.capabilities.file_attach]
supported   = false
required    = false
degradation = "Paste file contents into the prompt."
