#!/usr/bin/env bash
# Harness 公共 shell 库
# 由 harness v{{ harness_version }} 生成
#
# 在 harness 脚本中以下面方式 source 本文件:
#   source "$(dirname "${BASH_SOURCE[0]}")/lib/common.sh"

# --- 颜色 ---

if [ -t 1 ] && command -v tput &>/dev/null; then
    RED="$(tput setaf 1)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    BLUE="$(tput setaf 4)"
    BOLD="$(tput bold)"
    RESET="$(tput sgr0)"
else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    BOLD=""
    RESET=""
fi

# --- 日志 ---

header() {
    echo "${BOLD}${BLUE}=== $* ===${RESET}"
}

step() {
    echo "${BOLD}--- $* ---${RESET}"
}

info() {
    echo "${BLUE}[info]${RESET} $*"
}

ok() {
    echo "${GREEN}[ok]${RESET} $*"
}

warn() {
    echo "${YELLOW}[warn]${RESET} $*" >&2
}

err() {
    echo "${RED}[error]${RESET} $*" >&2
}

# --- 错误处理 ---

# 通过 ERR trap 输出失败的命令和行号
_harness_err_trap() {
    local exit_code=$?
    local line_no="${BASH_LINENO[0]}"
    local command="${BASH_COMMAND}"
    err "命令失败 (line $line_no, exit $exit_code): $command"
}

# 仅在调用方启用了 set -e 时才挂载 ERR trap
if [[ "${SHELLOPTS}" =~ errexit ]]; then
    trap '_harness_err_trap' ERR
fi

# --- 工具函数 ---

# 检查指定命令是否存在
require_cmd() {
    local cmd="$1"
    local msg="${2:-未找到所需命令 '$cmd'}"
    if ! command -v "$cmd" &>/dev/null; then
        err "$msg"
        return 1
    fi
}

# 执行命令并捕获输出;仅在失败时打印
quiet_run() {
    local output
    if output=$("$@" 2>&1); then
        return 0
    else
        local exit_code=$?
        echo "$output" >&2
        return $exit_code
    fi
}

# 取项目根目录 (即包含 .harness/ 的目录)
find_project_root() {
    local dir="${1:-$(pwd)}"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.harness" ]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    err "未找到项目根目录 (向上查找未见 .harness/ 目录)"
    return 1
}

# 计算耗时辅助函数
_harness_start_time="${EPOCHSECONDS:-$(date +%s)}"

elapsed() {
    local now="${EPOCHSECONDS:-$(date +%s)}"
    local secs=$(( now - _harness_start_time ))
    echo "${secs}s"
}
