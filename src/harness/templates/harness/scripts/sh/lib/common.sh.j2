#!/usr/bin/env bash
# Harness Common Shell Library
# Generated by harness v{{ harness_version }}
#
# Source this file in harness shell scripts:
#   source "$(dirname "${BASH_SOURCE[0]}")/lib/common.sh"

# --- Colors ---

if [ -t 1 ] && command -v tput &>/dev/null; then
    RED="$(tput setaf 1)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    BLUE="$(tput setaf 4)"
    BOLD="$(tput bold)"
    RESET="$(tput sgr0)"
else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    BOLD=""
    RESET=""
fi

# --- Logging ---

header() {
    echo "${BOLD}${BLUE}=== $* ===${RESET}"
}

step() {
    echo "${BOLD}--- $* ---${RESET}"
}

info() {
    echo "${BLUE}[info]${RESET} $*"
}

ok() {
    echo "${GREEN}[ok]${RESET} $*"
}

warn() {
    echo "${YELLOW}[warn]${RESET} $*" >&2
}

err() {
    echo "${RED}[error]${RESET} $*" >&2
}

# --- Error Handling ---

# Trap ERR to print the failing command and line number
_harness_err_trap() {
    local exit_code=$?
    local line_no="${BASH_LINENO[0]}"
    local command="${BASH_COMMAND}"
    err "Command failed (line $line_no, exit $exit_code): $command"
}

# Enable ERR trap only if the caller has set -e
if [[ "${SHELLOPTS}" =~ errexit ]]; then
    trap '_harness_err_trap' ERR
fi

# --- Utility Functions ---

# Check if a command exists
require_cmd() {
    local cmd="$1"
    local msg="${2:-Required command '$cmd' not found}"
    if ! command -v "$cmd" &>/dev/null; then
        err "$msg"
        return 1
    fi
}

# Run a command and capture output; print only on failure
quiet_run() {
    local output
    if output=$("$@" 2>&1); then
        return 0
    else
        local exit_code=$?
        echo "$output" >&2
        return $exit_code
    fi
}

# Get the project root (directory containing .harness/)
find_project_root() {
    local dir="${1:-$(pwd)}"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.harness" ]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    err "Could not find project root (no .harness/ directory found)"
    return 1
}

# Elapsed time helper
_harness_start_time="${EPOCHSECONDS:-$(date +%s)}"

elapsed() {
    local now="${EPOCHSECONDS:-$(date +%s)}"
    local secs=$(( now - _harness_start_time ))
    echo "${secs}s"
}
