#!/usr/bin/env bash
# Harness 统一 Verify 脚本 —— {{ project_name }}
# 由 harness v{{ harness_version }} 于 {{ timestamp }} 生成
#
# 本脚本是项目验证 (verification) 的 **唯一真相源**。
# 编辑器钩子、pre-commit 检查、CI pipeline 都应调用本脚本,
# 而不是直接调用各自的 lint / typecheck / test 命令。
#
# 用法:
#   .harness/scripts/sh/verify.sh          # 跑完整套检查
#   .harness/scripts/sh/verify.sh lint      # 仅 lint
#   .harness/scripts/sh/verify.sh typecheck # 仅 typecheck
#   .harness/scripts/sh/verify.sh test      # 仅测试
#   .harness/scripts/sh/verify.sh quick     # lint + typecheck

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

# --- 技术栈识别 ---

detect_stack() {
    if [ -f "$PROJECT_ROOT/pyproject.toml" ] || [ -f "$PROJECT_ROOT/setup.py" ]; then
        echo "python"
    elif [ -f "$PROJECT_ROOT/package.json" ]; then
        echo "node"
    elif [ -f "$PROJECT_ROOT/pom.xml" ] || [ -f "$PROJECT_ROOT/build.gradle" ] || [ -f "$PROJECT_ROOT/build.gradle.kts" ]; then
        echo "jvm"
    elif [ -f "$PROJECT_ROOT/go.mod" ]; then
        echo "go"
    elif [ -f "$PROJECT_ROOT/Cargo.toml" ]; then
        echo "rust"
    else
        echo "unknown"
    fi
}

STACK="$(detect_stack)"

# --- 检查项 ---

run_lint() {
    step "执行 lint ($STACK)"
    case "$STACK" in
        python)
            if command -v ruff &>/dev/null; then
                ruff check "$PROJECT_ROOT"
            elif command -v flake8 &>/dev/null; then
                flake8 "$PROJECT_ROOT"
            elif command -v pylint &>/dev/null; then
                pylint "$PROJECT_ROOT/src" || true
            else
                warn "未找到 Python linter (请安装 ruff、flake8 或 pylint)"
                return 0
            fi
            ;;
        node)
            if [ -f "$PROJECT_ROOT/node_modules/.bin/eslint" ]; then
                npx eslint . --max-warnings 0
            elif [ -f "$PROJECT_ROOT/biome.json" ] || [ -f "$PROJECT_ROOT/biome.jsonc" ]; then
                npx biome check .
            else
                warn "未找到 JS/TS linter (请安装 eslint 或 biome)"
                return 0
            fi
            ;;
        jvm)
            if [ -f "$PROJECT_ROOT/pom.xml" ]; then
                mvn -f "$PROJECT_ROOT/pom.xml" checkstyle:check -q 2>/dev/null || true
            fi
            ;;
        go)
            (cd "$PROJECT_ROOT" && golangci-lint run ./... 2>/dev/null) || {
                warn "未找到 golangci-lint,回退到 go vet"
                (cd "$PROJECT_ROOT" && go vet ./...)
            }
            ;;
        rust)
            (cd "$PROJECT_ROOT" && cargo clippy -- -D warnings)
            ;;
        *)
            warn "未知技术栈,跳过 lint"
            return 0
            ;;
    esac
    ok "lint 通过"
}

run_typecheck() {
    step "执行 typecheck ($STACK)"
    case "$STACK" in
        python)
            if command -v mypy &>/dev/null; then
                mypy "$PROJECT_ROOT/src" --ignore-missing-imports
            elif command -v pyright &>/dev/null; then
                pyright "$PROJECT_ROOT/src"
            else
                warn "未找到 Python type checker (请安装 mypy 或 pyright)"
                return 0
            fi
            ;;
        node)
            if [ -f "$PROJECT_ROOT/tsconfig.json" ]; then
                npx tsc --noEmit
            else
                warn "未找到 tsconfig.json,跳过 typecheck"
                return 0
            fi
            ;;
        go)
            # go vet 已覆盖类型检查;在 lint 阶段执行
            ok "Go 类型检查由 go vet 覆盖"
            return 0
            ;;
        rust)
            # cargo clippy 已覆盖类型检查;在 lint 阶段执行
            ok "Rust 类型检查由 cargo clippy 覆盖"
            return 0
            ;;
        *)
            warn "未知技术栈,跳过 typecheck"
            return 0
            ;;
    esac
    ok "typecheck 通过"
}

run_test() {
    step "执行测试 ($STACK)"
    case "$STACK" in
        python)
            if command -v pytest &>/dev/null; then
                pytest "$PROJECT_ROOT" -v --tb=short
            elif [ -f "$PROJECT_ROOT/manage.py" ]; then
                python "$PROJECT_ROOT/manage.py" test
            else
                python -m unittest discover "$PROJECT_ROOT/tests"
            fi
            ;;
        node)
            if grep -q '"test"' "$PROJECT_ROOT/package.json" 2>/dev/null; then
                (cd "$PROJECT_ROOT" && npm test)
            elif [ -f "$PROJECT_ROOT/node_modules/.bin/vitest" ]; then
                npx vitest run
            elif [ -f "$PROJECT_ROOT/node_modules/.bin/jest" ]; then
                npx jest
            else
                warn "未找到测试运行器,跳过测试"
                return 0
            fi
            ;;
        jvm)
            if [ -f "$PROJECT_ROOT/pom.xml" ]; then
                mvn -f "$PROJECT_ROOT/pom.xml" test -q
            elif [ -f "$PROJECT_ROOT/gradlew" ]; then
                "$PROJECT_ROOT/gradlew" test
            elif [ -f "$PROJECT_ROOT/build.gradle" ] || [ -f "$PROJECT_ROOT/build.gradle.kts" ]; then
                gradle test
            fi
            ;;
        go)
            (cd "$PROJECT_ROOT" && go test ./... -v)
            ;;
        rust)
            (cd "$PROJECT_ROOT" && cargo test)
            ;;
        *)
            warn "未知技术栈,跳过测试"
            return 0
            ;;
    esac
    ok "测试通过"
}

# --- 主入口 ---

main() {
    local target="${1:-all}"

    header "Harness Verify —— {{ project_name }}"
    info "Stack: $STACK"
    info "Target: $target"
    echo ""

    local exit_code=0

    case "$target" in
        lint)
            run_lint || exit_code=$?
            ;;
        typecheck)
            run_typecheck || exit_code=$?
            ;;
        test)
            run_test || exit_code=$?
            ;;
        quick)
            run_lint || exit_code=$?
            run_typecheck || { exit_code=$?; }
            ;;
        all)
            run_lint || exit_code=$?
            run_typecheck || { exit_code=$?; }
            run_test || { exit_code=$?; }
            ;;
        *)
            err "未知 target: $target"
            info "用法: verify.sh [lint|typecheck|test|quick|all]"
            exit 1
            ;;
    esac

    echo ""
    if [ $exit_code -eq 0 ]; then
        ok "所有检查通过"
    else
        err "验证失败 (exit code $exit_code)"
    fi

    exit $exit_code
}

main "$@"
