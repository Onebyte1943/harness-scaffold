#!/usr/bin/env bash
# Harness Unified Verify Script — {{ project_name }}
# Generated by harness v{{ harness_version }} at {{ timestamp }}
#
# This script is the SINGLE SOURCE OF TRUTH for project verification.
# Hooks, pre-commit checks, and CI pipelines should all call this script
# rather than running lint/typecheck/test commands directly.
#
# Usage:
#   .harness/scripts/sh/verify.sh          # Run all checks
#   .harness/scripts/sh/verify.sh lint      # Run only lint
#   .harness/scripts/sh/verify.sh typecheck # Run only typecheck
#   .harness/scripts/sh/verify.sh test      # Run only tests
#   .harness/scripts/sh/verify.sh quick     # Lint + typecheck only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

# --- Stack Detection ---

detect_stack() {
    if [ -f "$PROJECT_ROOT/pyproject.toml" ] || [ -f "$PROJECT_ROOT/setup.py" ]; then
        echo "python"
    elif [ -f "$PROJECT_ROOT/package.json" ]; then
        echo "node"
    elif [ -f "$PROJECT_ROOT/pom.xml" ] || [ -f "$PROJECT_ROOT/build.gradle" ] || [ -f "$PROJECT_ROOT/build.gradle.kts" ]; then
        echo "jvm"
    elif [ -f "$PROJECT_ROOT/go.mod" ]; then
        echo "go"
    elif [ -f "$PROJECT_ROOT/Cargo.toml" ]; then
        echo "rust"
    else
        echo "unknown"
    fi
}

STACK="$(detect_stack)"

# --- Check Runners ---

run_lint() {
    step "Running lint ($STACK)"
    case "$STACK" in
        python)
            if command -v ruff &>/dev/null; then
                ruff check "$PROJECT_ROOT"
            elif command -v flake8 &>/dev/null; then
                flake8 "$PROJECT_ROOT"
            elif command -v pylint &>/dev/null; then
                pylint "$PROJECT_ROOT/src" || true
            else
                warn "No Python linter found (install ruff, flake8, or pylint)"
                return 0
            fi
            ;;
        node)
            if [ -f "$PROJECT_ROOT/node_modules/.bin/eslint" ]; then
                npx eslint . --max-warnings 0
            elif [ -f "$PROJECT_ROOT/biome.json" ] || [ -f "$PROJECT_ROOT/biome.jsonc" ]; then
                npx biome check .
            else
                warn "No JS/TS linter found (install eslint or biome)"
                return 0
            fi
            ;;
        jvm)
            if [ -f "$PROJECT_ROOT/pom.xml" ]; then
                mvn -f "$PROJECT_ROOT/pom.xml" checkstyle:check -q 2>/dev/null || true
            fi
            ;;
        go)
            (cd "$PROJECT_ROOT" && golangci-lint run ./... 2>/dev/null) || {
                warn "golangci-lint not found, falling back to go vet"
                (cd "$PROJECT_ROOT" && go vet ./...)
            }
            ;;
        rust)
            (cd "$PROJECT_ROOT" && cargo clippy -- -D warnings)
            ;;
        *)
            warn "Unknown stack — skipping lint"
            return 0
            ;;
    esac
    ok "Lint passed"
}

run_typecheck() {
    step "Running typecheck ($STACK)"
    case "$STACK" in
        python)
            if command -v mypy &>/dev/null; then
                mypy "$PROJECT_ROOT/src" --ignore-missing-imports
            elif command -v pyright &>/dev/null; then
                pyright "$PROJECT_ROOT/src"
            else
                warn "No Python type checker found (install mypy or pyright)"
                return 0
            fi
            ;;
        node)
            if [ -f "$PROJECT_ROOT/tsconfig.json" ]; then
                npx tsc --noEmit
            else
                warn "No tsconfig.json found — skipping typecheck"
                return 0
            fi
            ;;
        go)
            # go vet covers type checking; already run in lint
            ok "Go type checking covered by go vet"
            return 0
            ;;
        rust)
            # cargo clippy covers type checking; already run in lint
            ok "Rust type checking covered by cargo clippy"
            return 0
            ;;
        *)
            warn "Unknown stack — skipping typecheck"
            return 0
            ;;
    esac
    ok "Typecheck passed"
}

run_test() {
    step "Running tests ($STACK)"
    case "$STACK" in
        python)
            if command -v pytest &>/dev/null; then
                pytest "$PROJECT_ROOT" -v --tb=short
            elif [ -f "$PROJECT_ROOT/manage.py" ]; then
                python "$PROJECT_ROOT/manage.py" test
            else
                python -m unittest discover "$PROJECT_ROOT/tests"
            fi
            ;;
        node)
            if grep -q '"test"' "$PROJECT_ROOT/package.json" 2>/dev/null; then
                (cd "$PROJECT_ROOT" && npm test)
            elif [ -f "$PROJECT_ROOT/node_modules/.bin/vitest" ]; then
                npx vitest run
            elif [ -f "$PROJECT_ROOT/node_modules/.bin/jest" ]; then
                npx jest
            else
                warn "No test runner found — skipping tests"
                return 0
            fi
            ;;
        jvm)
            if [ -f "$PROJECT_ROOT/pom.xml" ]; then
                mvn -f "$PROJECT_ROOT/pom.xml" test -q
            elif [ -f "$PROJECT_ROOT/gradlew" ]; then
                "$PROJECT_ROOT/gradlew" test
            elif [ -f "$PROJECT_ROOT/build.gradle" ] || [ -f "$PROJECT_ROOT/build.gradle.kts" ]; then
                gradle test
            fi
            ;;
        go)
            (cd "$PROJECT_ROOT" && go test ./... -v)
            ;;
        rust)
            (cd "$PROJECT_ROOT" && cargo test)
            ;;
        *)
            warn "Unknown stack — skipping tests"
            return 0
            ;;
    esac
    ok "Tests passed"
}

# --- Main ---

main() {
    local target="${1:-all}"

    header "Harness Verify — {{ project_name }}"
    info "Stack: $STACK"
    info "Target: $target"
    echo ""

    local exit_code=0

    case "$target" in
        lint)
            run_lint || exit_code=$?
            ;;
        typecheck)
            run_typecheck || exit_code=$?
            ;;
        test)
            run_test || exit_code=$?
            ;;
        quick)
            run_lint || exit_code=$?
            run_typecheck || { exit_code=$?; }
            ;;
        all)
            run_lint || exit_code=$?
            run_typecheck || { exit_code=$?; }
            run_test || { exit_code=$?; }
            ;;
        *)
            err "Unknown target: $target"
            info "Usage: verify.sh [lint|typecheck|test|quick|all]"
            exit 1
            ;;
    esac

    echo ""
    if [ $exit_code -eq 0 ]; then
        ok "All checks passed"
    else
        err "Verification failed (exit code $exit_code)"
    fi

    exit $exit_code
}

main "$@"
